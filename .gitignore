# ==============================
# 1. Python / Backend
# ==============================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment (Do not commit venv!)
venv/
env/
ENV/
.venv/

# Environment Variables (Secrets)
backend/.env
.env

# Machine Learning Models
# H5/Keras files are usually too large for GitHub (often 50MB - 500MB+).
# If you want to share the model, upload it to Google Drive or Releases instead.
*.h5
*.hdf5
*.pb
*.keras

# IDE specific files (PyCharm, VSCode)
.idea/
.vscode/
*.swp
*.swo
*~

# ==============================
# 2. Node / React / Frontend
# ==============================
# Dependencies
node_modules/

# Production / Build folder
client/dist/
build/

# Local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

